// tank.h
#pragma once
#include <string
#include <cmath>

enum class TankType {
    "configurations": [
    
    ]
    Vertical,
    Horizontal
};

class Tank {
private:
    std::string name_;
    TankType type_;
    double diameter_;      // в сантиметрах
    double length_;        // для горизонтальных (см)
    double height_;        // для вертикальных (см)
    double level_;         // текущий уровень наполнения (см)
    double temperature_;   // температура (°C)
    double base_density_;  // плотность при 20°C (кг/л)

public:
    Tank(const std::string& name, TankType type, double diameter, 
         double length, double height, double base_density = 0.7488)
        : name_(name), type_(type), diameter_(diameter),
          length_(length), height_(height), level_(0.0),
          temperature_(20.0), base_density_(base_density) {}

    // Геттеры
    std::string getName() const { return name_; }
    TankType getType() const { return type_; }
    double getDiameter() const { return diameter_; }
    double getLength() const { return length_; }
    double getHeight() const { return height_; }
    double getLevel() const { return level_; }
    double getTemperature() const { return temperature_; }
    double getBaseDensity() const { return base_density_; }

    // Сеттеры
    void setLevel(double level) { 
        level_ = std::max(0.0, std::min(level, getMaxLevel())); 
    }
    void setTemperature(double temp) { temperature_ = temp; }
    void setBaseDensity(double density) { base_density_ = density; }

    // Расчет максимального уровня
    double getMaxLevel() const {
        return (type_ == TankType::Vertical) ? height_ : diameter_;
    }

    // Расчет объема резервуара (литры)
    double calculateTotalVolume() const {
        double radius = diameter_ / 2.0;
        if (type_ == TankType::Vertical) {
            return M_PI * radius * radius * height_ / 1000.0;
        } else {
            return M_PI * radius * radius * length_ / 1000.0;
        }
    }

    // Расчет текущего объема (литры)
    double calculateCurrentVolume() const {
        double radius = diameter_ / 2.0;
        double vol_m3;
        
        if (type_ == TankType::Vertical) {
            vol_m3 = M_PI * radius * radius * level_;
        } else {
            // Для горизонтального цилиндра
            double r = radius;
            double h = level_;
            if (h > diameter_) h = diameter_;
            
            // Сегмент круга
            double segment_area = r * r * acos((r - h) / r) - 
                                 (r - h) * sqrt(2 * r * h - h * h);
            vol_m3 = segment_area * length_;
        }
        return vol_m3 / 1000.0; // Переводим в литры
    }

    // Расчет массы (кг)
    double calculateMass() const {
        return calculateCurrentVolume() * base_density_;
    }

    // Обновление данных с датчиков
    void updateSensorData(double new_level, double new_temp) {
        setLevel(new_level);
        setTemperature(new_temp);
    }
};
